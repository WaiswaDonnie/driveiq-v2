# DriveIQ environment variables
# Copy this file to `.env` and fill in your real keys.
# Expo automatically inlines EXPO_PUBLIC_* vars at build time (SDK 49+).

# TheSportsDB Premium key — required for the venue-loop fetch path that
# pulls every sport at every London venue in ~25 API calls.
#
# Without a key set, the app falls back to free-tier sport-by-day enumeration
# (works but slower, lower coverage, and uses the shared throttled "123" key).
#
# Get a Premium key for $9/month at https://www.thesportsdb.com/pricing —
# the key is shown on your profile page after signing up.
#
# Then run `node scripts/resolve-venue-ids.mjs` once to populate the venue
# IDs in src/data/londonVenues.ts.
EXPO_PUBLIC_SPORTSDB_API_KEY=

# Football-Data.org token — real current football fixtures (Premier League,
# Championship, FA Cup, Champions League). Free tier: 10 requests/minute.
#
# Sign up for a free token at https://www.football-data.org/client/register
# (instant, no payment, no card). The token is emailed to you immediately;
# paste it below. The map populates Arsenal / Chelsea / Spurs / West Ham /
# Palace / Fulham / Brentford / QPR / Millwall fixtures from real data.
EXPO_PUBLIC_FOOTBALLDATA_API_KEY=

# Ticketmaster Discovery API (concerts, theatre, comedy, film, family events,
# plus ticketed sports like NFL London, NBA London, boxing nights, etc).
# https://developer.ticketmaster.com/
EXPO_PUBLIC_TICKETMASTER_API_KEY=

# Google Maps SDK key (required for iOS + Android map rendering when using
# react-native-maps with the Google provider). NOT prefixed with EXPO_PUBLIC_
# because it only needs to flow into the native config — not the JS bundle.
# Create one in Google Cloud Console: https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=

# Google Directions API key (used by the routing layer to fetch driving
# routes + traffic-aware ETAs when the user taps "Get directions" on an
# event, traffic incident, or airport). EXPO_PUBLIC_-prefixed so it can be
# read from JS at runtime. Can be the same key as GOOGLE_MAPS_API_KEY as
# long as the Directions API is enabled on the project; restrict the key
# to the Directions API + your bundle identifiers in production.
EXPO_PUBLIC_GOOGLE_DIRECTIONS_API_KEY=

# Firebase web config (Authentication). These are not secrets — Firebase web
# config is safe to ship client-side; access is controlled by Firebase Auth
# and Security Rules. Find them in Firebase Console → Project settings →
# General → "Your apps" → SDK setup and configuration.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=
